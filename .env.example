# Finnhub API Key (optional — for stock logos, calendar)
# Get free key at https://finnhub.io/register
FINNHUB_API_KEY=

# Anthropic API Key (optional — for AI analysis features)
# Get key at https://console.anthropic.com
# ANTHROPIC_API_KEY=

# ===== Trading Bot Notifications =====

# Telegram Bot (แนะนำ!)
# 1. เปิด Telegram → ค้นหา @BotFather → /newbot → ได้ Token
# 2. ค้นหา @userinfobot → พิมพ์อะไรก็ได้ → ได้ Chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# LINE Notify (optional)
# Get token at: https://notify-bot.line.me/
# LINE_NOTIFY_TOKEN=

# Turso remote database (optional)
# Set in production if you want a shared cloud database.
# TURSO_DATABASE_URL=libsql://money-trade-kitcr2569.aws-ap-south-1.turso.io
# TURSO_AUTH_TOKEN=<your-auth-token>

# Bot Cron Secret (optional — protect /api/bot/cron endpoint)
# BOT_CRON_SECRET=
